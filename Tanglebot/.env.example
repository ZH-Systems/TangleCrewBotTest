# ── Bot credentials ────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_application_client_id_here
CLAN_ID=your_server_id_here
OWNER_ID=your_discord_user_id_here

# ── Roles ──────────────────────────────────────────────────────────────────────
OWNER_ROLE_ID=your_owner_role_id_here
COORDINATOR_ROLE_ID=your_coordinator_role_id_here
TEMPLAR_ROLE_ID=your_templar_role_id_here
# Donation tier roles (leave blank to skip that tier)
DONATION_GOLD_ROLE_ID=
DONATION_DIAMOND_ROLE_ID=
DONATION_ZENYTE_ROLE_ID=

# ── Donation leaderboard (/updatedonations) ────────────────────────────────────
# Paste any Google Sheets URL (edit link, share link, or export link — all work)
# Make sure the sheet is shared: Share → Anyone with the link → Viewer
DONATIONS_SHEET_URL=https://docs.google.com/spreadsheets/d/1IUlKpFvdGBPy9NOXpQqlFcTqe1rJHkGHcqPblhUXBAs/edit?usp=drive_link
# Channel where the leaderboard message is posted
DONATIONS_CHANNEL_ID=
# GP thresholds per tier (raw numbers, e.g. 75000000 = 75M)
DONATION_GOLD_THRESHOLD=
DONATION_DIAMOND_THRESHOLD=
DONATION_ZENYTE_THRESHOLD=
# Custom emoji IDs for each tier and the total donation line
DONATION_EMOJI_GOLD=
DONATION_EMOJI_DIAMOND=
DONATION_EMOJI_ZENYTE=
DONATION_EMOJI_COINS=


# ── KC/drop proof submission intake ───────────────────────────────────────────
# Leave all three blank/unset to disable.
# JSON object mapping Discord submission channel IDs to site event IDs.
DISCORD_SUBMISSION_CHANNEL_EVENT_MAP=
SUPABASE_DISCORD_KC_INTAKE_URL=https://wpoldbyuqkmzdxngnwkz.supabase.co/functions/v1/discord-manual-kc-intake
DISCORD_KC_INTAKE_SECRET=
